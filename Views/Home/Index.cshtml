@{
    ViewData["Title"] = "Panel de Control";
}

<style>
    /* Efecto de elevación para las tarjetas */
    .card-hover {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.1) !important;
        }
    /* Estilo para las cabeceras de tabla */
    .table-custom-header {
        background-color: #f8f9fa;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        color: #6c757d;
    }
    /* Bordes redondeados consistentes */
    .rounded-xl {
        border-radius: 1rem !important;
    }
</style>

<div class="d-flex align-items-center justify-content-between mb-4 mt-2">
    <div>
        <h4 class="fw-bold text-dark mb-0">Hola, @User.Identity.Name 👋</h4>
        <p class="text-muted mb-0">Esto es lo que sucede hoy en la clínica.</p>
    </div>
    <div class="d-none d-sm-block">
        <div class="bg-white shadow-sm p-2 px-3 rounded-pill border">
            <i class="bi bi-calendar3 text-success me-2"></i>
            <span class="fw-medium">@DateTime.Now.ToString("dddd, dd 'de' MMMM")</span>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6 col-lg-4 mb-3">
        <div class="card card-hover shadow-sm border-0 rounded-xl h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-start justify-content-between">
                    <div>
                        <p class="text-muted fw-bold small mb-2">PACIENTES TOTALES</p>
                        <h2 class="fw-extrabold mb-0">@Model.TotalPacientes</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-people-fill text-success fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex align-items-center text-success small">
                        <i class="bi bi-shield-check me-1"></i>
                        <span>Base de datos sincronizada</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4 mb-3">
        <div class="card card-hover shadow-sm border-0 rounded-xl h-100 border-start border-primary border-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-start justify-content-between">
                    <div>
                        <p class="text-muted fw-bold small mb-2">AGENDA DE HOY</p>
                        <h2 class="fw-extrabold mb-0">@Model.TotalCitasHoy</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                        <i class="bi bi-calendar2-heart text-primary fs-4"></i>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <div class="d-flex align-items-center text-primary small">
                        <i class="bi bi-info-circle me-1"></i>
                        <span>Citas pendientes de atención</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

   
</div>

<div class="card shadow-sm border-0 rounded-xl">
    <div class="card-header bg-white py-4 border-0">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h5 class="m-0 fw-bold text-dark">
                    Próximas Sesiones de Fisioterapia
                </h5>
                <p class="text-muted small mb-0 mt-1">Lista de pacientes ordenados por horario de llegada.</p>
            </div>
           
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-custom-header">
                    <tr>
                        <th class="ps-4 py-3">Paciente</th>
                        <th class="py-3">Horario</th>
                        <th class="py-3">Motivo</th>
                        <th class="py-3 text-center">Estado de Cita</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ProximasCitas != null && Model.ProximasCitas.Count > 0)
                    {
                        foreach (var cita in Model.ProximasCitas)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-soft bg-success bg-opacity-10 text-success rounded-circle p-2 me-3">
                                            <i class="bi bi-person-badge fs-5"></i>
                                        </div>
                                        <div>
                                            <span class="fw-bold text-dark d-block">@cita.NombrePaciente</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold">@cita.FechaCita.ToString("hh:mm tt")</span>
                                        <span class="text-muted small text-capitalize">@cita.FechaCita.ToString("dd MMM")</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <span class="text-dark">@cita.Motivo</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @{
                                        string estadoNormalizado = cita.Estado?.ToLower() ?? "pendiente";
                                        string statusClass = estadoNormalizado switch
                                        {
                                            "Pendiente" => "bg-warning text-dark border-warning",
                                            "Completada" => "bg-success text-white border-success",
                                            "Cancelada" => "bg-danger text-white border-danger",
                                            _ => "bg-secondary text-white border-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass bg-opacity-75 border-start border-4" style="padding: 0.6em 1.2em; font-weight: 600;">
                                        @cita.Estado
                                    </span>
                                </td>
                          
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="py-4">
                                    <i class="bi bi-calendar-x-fill text-muted mb-3 d-block" style="font-size: 3rem; opacity: 0.3;"></i>
                                    <h5 class="text-dark fw-bold">Sin terapias pendientes</h5>
                                    <p class="text-muted">No tienes citas programadas para el resto de hoy.</p>
                                    <a asp-controller="CitaMedica" asp-action="Crear" class="btn btn-success btn-sm rounded-pill mt-2">
                                        <i class="bi bi-plus-lg me-1"></i> Agendar nueva terapia
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>