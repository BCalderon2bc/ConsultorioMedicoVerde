@model ConsultorioVerde.Web.Models.MedicoViewModel

@{
    ViewData["Title"] = "Nuevo Médico";
}

<style>
    .border-verde {
        border-color: #198754 !important;
    }

        .border-verde:focus {
            border-color: #198754 !important;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25) !important;
        }

    .rounded-xl {
        border-radius: 1rem !important;
    }

    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.05);
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-person-plus-fill me-2"></i>Registrar Médico
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Crear" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Nombre" class="form-label fw-bold">Nombre</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-person"></i></span>
                                    <input asp-for="Nombre" class="form-control border-verde solo-letras" required />
                                </div>
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Apellido" class="form-label fw-bold">Apellido</label>
                                <input asp-for="Apellido" class="form-control border-verde solo-letras" />
                                <span asp-validation-for="Apellido" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Especialidad" class="form-label fw-bold">Especialidad</label>
                                <input asp-for="Especialidad" class="form-control border-verde solo-letras" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="NumeroRegistroMINSA" class="form-label fw-bold">Registro MINSA</label>
                                <input asp-for="NumeroRegistroMINSA" class="form-control border-verde" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Telefono" class="form-label fw-bold">Teléfono</label>
                                <input asp-for="Telefono" class="form-control border-verde telefono-mask" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Correo" class="form-label fw-bold">Correo Electrónico</label>
                                <input asp-for="Correo" class="form-control border-verde correo-valido" />
                                <span asp-validation-for="Correo" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="border-top mt-4 pt-3 d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 me-2">
                                <i class="bi bi-arrow-left me-1"></i>Regresar
                            </a>
                            <form asp-action="Crear" method="post">
                                    <button type="submit" class="btn btn-success px-5 shadow">
                                        <i class="bi bi-save me-1"></i>Guardar Médico
                                    </button>
                            </form>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}