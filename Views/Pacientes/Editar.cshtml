@model ConsultorioVerde.Web.Models.PacienteViewModel

@{
    ViewData["Title"] = "Editar Paciente";
}

<style>
    .border-verde {
        border-color: #198754 !important;
    }

        .border-verde:focus {
            border-color: #198754 !important;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25) !important;
        }

    .rounded-xl {
        border-radius: 1rem !important;
    }

    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.05);
    }

    .btn-verde {
        background-color: #198754;
        color: white;
        border: none;
    }

        .btn-verde:hover {
            background-color: #157347;
            color: white;
        }
</style>

<div class="container mt-4 mb-5">
    <div class="card shadow-lg border-0 rounded-xl overflow-hidden">
        <div class="card-header bg-success text-white py-3">
            <div class="d-flex align-items-center">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-pencil-square me-2"></i>Actualizar Expediente de Paciente
                </h5>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            <form asp-action="Editar" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                @* CAMPOS OCULTOS - CRUCIALES PARA LA ACTUALIZACIÓN *@
                <input type="hidden" asp-for="IdPaciente" />
                <input type="hidden" asp-for="FechaCreacion" />
                <input type="hidden" asp-for="UsuarioCreacion" />
                <input type="hidden" asp-for="Activo" />

                <div class="row">
                    @* --- SECCIÓN 1: INFORMACIÓN PERSONAL --- *@
                    <div class="col-12 mb-4">
                        <h6 class="text-success fw-bold text-uppercase small mb-3 border-bottom pb-2">
                            <i class="bi bi-info-circle-fill me-2"></i>Información Personal
                        </h6>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Nombres</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-person"></i></span>
                            <input asp-for="Nombre" class="form-control border-verde solo-letras" placeholder="Ej: Juan Antonio" required />
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Apellidos</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-person"></i></span>
                            <input asp-for="Apellido" class="form-control border-verde solo-letras" placeholder="Ej: Pérez García" required />
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Identificación (Cédula)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-card-text"></i></span>
                            <input asp-for="Identificacion" class="form-control border-verde cedula-ni" placeholder="000-000000-0000X" required />
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Fecha de Nacimiento</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-calendar-event"></i></span>
                            <input asp-for="FechaNacimiento" type="date" class="form-control border-verde" />
                        </div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Género</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-gender-ambiguous"></i></span>
                            <select asp-for="Genero" class="form-select border-verde">
                                <option value="M">Masculino</option>
                                <option value="F">Femenino</option>
                                <option value="O">Otro</option>
                            </select>
                        </div>
                    </div>

                    @* --- SECCIÓN 2: CONTACTO --- *@
                    <div class="col-12 mt-3 mb-3">
                        <h6 class="text-success fw-bold text-uppercase small mb-3 border-bottom pb-2">
                            <i class="bi bi-telephone-fill me-2"></i>Información de Contacto
                        </h6>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Teléfono / WhatsApp</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-whatsapp"></i></span>
                            <input asp-for="Telefono" class="form-control border-verde telefono-mask" placeholder="8888-8888" />
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Correo Electrónico</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Correo" class="form-control border-verde correo-valido" placeholder="ejemplo@correo.com" />
                        </div>
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12 mb-4">
                        <label class="form-label fw-bold">Dirección Domiciliar</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-verde text-success"><i class="bi bi-geo-alt"></i></span>
                            <textarea asp-for="Direccion" class="form-control border-verde" rows="2" placeholder="Barrio, número de casa, puntos de referencia..."></textarea>
                        </div>
                    </div>
                </div>

                @* --- BOTONES DE ACCIÓN --- *@
                <div class="border-top mt-4 pt-3 d-flex justify-content-between align-items-center">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 m-2">
                        <i class="bi bi-arrow-left me-1"></i>Regresar
                    </a>
                    <button type="submit" class="btn btn-verde px-5 shadow">
                        <i class="bi bi-save me-1"></i>Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}