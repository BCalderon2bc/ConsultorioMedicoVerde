@model RecetaViewModel

<style>
    .border-verde {
        border-color: #198754 !important;
    }

        .border-verde:focus {
            border-color: #198754 !important;
            box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25) !important;
        }

    .rounded-xl {
        border-radius: 1rem !important;
    }

    .bg-soft-success {
        background-color: rgba(25, 135, 84, 0.05);
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white py-3 text-center">
                    <h5 class="mb-0"><i class="bi bi-prescription2 me-2"></i>Nueva Receta Médica</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="GuardarReceta" method="post">
                        <input type="hidden" asp-for="IdConsulta" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Medicamento</label>
                            <input asp-for="Medicamento" class="form-control border-success-subtle" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Dosis</label>
                                <input asp-for="Dosis" class="form-control border-success-subtle"  />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Frecuencia</label>
                                <input asp-for="Frecuencia" class="form-control border-success-subtle" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Duración</label>
                            <input asp-for="Duracion" class="form-control border-success-subtle" />
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5">
                                <i class="bi bi-check-circle me-1"></i> Guardar Receta
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}