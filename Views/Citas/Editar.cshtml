@model ConsultorioVerde.Web.Models.CitaViewModel
@{
    ViewData["Title"] = "Editar Cita Médica";
    // Si el modelo o la fecha vienen nulos, evitamos el crash usando DateTime.Now
    var fechaCita = Model?.FechaCita ?? DateTime.Now;
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Editar Cita Médica #@(Model?.IdCita ?? 0)
                    </h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Editar" method="post" id="formEditarCita">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="IdCita" />
                        <input type="hidden" asp-for="UsuarioCreacion" />
                        <input type="hidden" asp-for="FechaCreacion" />
                        <input type="hidden" asp-for="FechaCita" id="FechaCitaFull" />

                        <div class="row g-3">
                            @* Paciente - Con protección de nulos *@
                            <div class="col-md-12">
                                <label class="form-label fw-bold text-muted small">PACIENTE</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-verde-subtle">
                                        <i class="bi bi-person-fill text-success"></i>
                                    </span>
                                    <select asp-for="IdPaciente" class="form-select border-start-0 border-verde-subtle bg-light" disabled
                                            asp-items="@(ViewBag.Pacientes != null ? new SelectList((System.Collections.IEnumerable)ViewBag.Pacientes, "IdPaciente", "NombreConCedula") : null)">
                                    </select>
                                    <input type="hidden" asp-for="IdPaciente" />
                                </div>
                            </div>

                            @* Médico - Con protección de nulos *@
                            <div class="col-md-12">
                                <label class="form-label fw-bold text-muted small">MÉDICO</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-verde-subtle">
                                        <i class="bi bi-person-badge-fill text-success"></i>
                                    </span>
                                    <select asp-for="IdMedico" class="form-select border-start-0 border-verde-subtle bg-light" disabled
                                            asp-items="@(ViewBag.Medicos != null ? new SelectList((System.Collections.IEnumerable)ViewBag.Medicos, "IdMedico", "NombreConEspecialidad") : null)">
                                    </select>
                                    <input type="hidden" asp-for="IdMedico" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Fecha de Cita</label>
                                <input type="date" id="fechaSolo" class="form-control border-verde-subtle"
                                       value="@fechaCita.ToString("yyyy-MM-dd")" required />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Hora</label>
                                <input type="time" id="horaSolo" class="form-control border-verde-subtle"
                                       value="@fechaCita.ToString("HH:mm")" required />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">Estado</label>
                                <select asp-for="Estado" class="form-select border-verde-subtle">
                                    <option value="Pendiente">Pendiente</option>
                                    <option value="Completada">Completada</option>
                                    <option value="Cancelada">Cancelada</option>
                                </select>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">Motivo</label>
                                <textarea asp-for="Motivo" class="form-control border-verde-subtle" rows="3"></textarea>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5 shadow">Guardar Cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>